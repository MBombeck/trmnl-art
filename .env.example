# TRMNL webhook UUID (from trmnl.com private plugin settings)
TRMNL_WEBHOOK_UUID=3b607cf6-508d-4480-9229-17edca1f69ee

# NASA API key (get free key at https://api.nasa.gov or use DEMO_KEY)
NASA_API_KEY=DEMO_KEY

# Schedule (hours in Europe/Berlin timezone)
RIJKSMUSEUM_HOUR=5
NASA_HOUR=12
TZ=Europe/Berlin

# App URL (how TRMNL reaches this service)
APP_URL=https://trmnl-art.bombeck.io

# Data directory (for persistent storage)
DATA_DIR=/app/data

# Port
PORT=8000
